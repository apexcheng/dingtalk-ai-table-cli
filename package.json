{
  "name": "dingtalk-ai-table-cli",
  "version": "0.7.3",
  "description": "OpenClaw 用的钉钉 AI 表格 MCP 安全调用层，基于 baseId / tableId / fieldId / recordId 体系。",
  "keywords": [
    "dingtalk",
    "ai-table",
    "mcp",
    "多维表",
    "openclaw",
    "skill"
  ],
  "author": "Marila@Dingtalk",
  "contributors": [
    "Marila@Dingtalk"
  ],
  "license": "MIT",
  "homepage": "https://github.com/apexcheng/dingtalk-ai-tableV2",
  "repository": {
    "type": "git",
    "url": "https://github.com/apexcheng/dingtalk-ai-tableV2.git"
  },
  "bugs": {
    "url": "https://github.com/apexcheng/dingtalk-ai-tableV2/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "mcporter": ">=0.8.1"
  },
  "clawhub": {
    "requiresBinaries": [
      "mcporter",
      "python3"
    ],
    "credentials": [
      {
        "name": "MCPORTER_CONFIG",
        "description": "优先使用 agent workspace/config/mcporter.json；如需手动指定，可把 mcporter 配置文件路径放到这个环境变量里。",
        "docs": "https://github.com/apexcheng/dingtalk-ai-table-cli",
        "storageMethod": "optional environment variable"
      }
    ]
  },
  "scripts": {
    "test": "python3 -B -m unittest -v"
  }
}
